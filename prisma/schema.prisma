generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Order {
  id                 String      @id @default(cuid())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  businessName       String?
  customerEmail      String
  customerName       String
  customerWhatsapp   String
  notes              String?     @db.Text
  orderId            String      @unique
  packageDescription String      @db.Text
  packageName        String
  price              Int
  quantity           Int         @default(1)
  status             OrderStatus @default(WAITING_PAYMENT)
  subtotal           Int
  total              Int
  invoice            Invoice?
  payment            Payment?

  @@index([customerEmail])
  @@index([status])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceId     String        @unique
  status        InvoiceStatus @default(PENDING)
  paymentMethod PaymentMethod
  orderIdRef    String        @unique
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  expiresAt     DateTime?
  order         Order         @relation(fields: [orderIdRef], references: [id], onDelete: Cascade)

  @@index([status])
}

model Payment {
  id                 String        @id @default(cuid())
  status             PaymentStatus @default(PENDING)
  paymentMethod      PaymentMethod
  provider           String?
  providerReference  String?
  providerPaymentUrl String?       @db.Text
  merchantOrderId    String?       @unique
  paymentCode        String?
  vaNumber           String?
  qrString           String?       @db.Text
  amount             Int
  orderIdRef         String        @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  order              Order         @relation(fields: [orderIdRef], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([providerReference])
}

enum OrderStatus {
  WAITING_PAYMENT
  PAID
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  VIRTUAL_ACCOUNT
  QRIS
  EWALLET
  BANK_TRANSFER_MANUAL
  EWALLET_MANUAL
}
